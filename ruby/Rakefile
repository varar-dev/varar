# frozen_string_literal: true

require 'rspec/core/rake_task'
require 'rubocop/rake_task'

RSpec::Core::RakeTask.new(:spec) do |t|
  t.pattern = 'packages/**/spec/**/*_spec.rb'
  t.rspec_opts = '-Ispec --require spec_helper'
end

# Formatting + linting. `rake rubocop:autocorrect` (or `-A`) applies fixes. Also
# lints the example projects' Ruby source with this same config (--config), so
# no warning or error slips through anywhere in the port. Only the .rb source
# dirs are added (not the Gemfile/Rakefile — tool-mandated names the FileName
# cop rejects); the ruby-minitest test/varar and lib are symlinks into
# ruby-rspec, so its shared files are covered via ruby-rspec (spec/ includes
# the spec/varar steps).
RuboCop::RakeTask.new do |task|
  task.patterns = [
    '.',
    '../examples/ruby-rspec/lib',
    '../examples/ruby-rspec/spec',
    '../examples/ruby-minitest/test'
  ]
  task.options = ['--config', '.rubocop.yml']
end

desc 'Fail if var-core requires the facade/runner (functional-core purity gate)'
task :lint_no_reexports do
  ruby 'scripts/lint_no_reexports.rb'
end

task default: %i[rubocop spec lint_no_reexports]
