{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": true,
  "ignoreWorkspaces": ["packages/cucumber"],
  "workspaces": {
    "packages/var-config": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-core": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-cli": {
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignoreDependencies": ["@oselvar/var"]
    },
    "packages/var-runner": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-vitest": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var": {
      "entry": [
        "src/index.ts",
        "tests/**/*.test.ts",
        "../../../conformance/bundles/**/*.steps.ts",
        "../../../conformance/bundles/**/*.md"
      ],
      "project": ["src/**/*.ts", "tests/**/*.ts", "../../../conformance/bundles/**/*.{ts,md}"]
    },
    "packages/var-language": {
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignoreDependencies": ["tree-sitter-typescript"]
    },
    "packages/var-lsp": {
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignoreDependencies": ["tree-sitter-typescript"]
    },
    "packages/var-vscode": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@oselvar/var-language", "@oselvar/var-lsp"]
    },
    "packages/var-examples": {
      "entry": ["**/*.md", "**/*.steps.ts"],
      "project": ["**/*.{ts,md}"]
    }
  },
  "ignore": [
    "var.config.ts",
    "**/tests/fixtures/**",
    "packages/website/src/layouts/Doc.astro",
    "**/!(package).json"
  ]
}
