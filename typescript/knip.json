{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "packages/config": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/core": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/cli": {
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignoreDependencies": ["@varar/varar"]
    },
    "packages/runner": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/vitest": {
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignoreDependencies": ["tree-sitter-typescript"]
    },
    "packages/varar": {
      "entry": ["tests/**/*.test.ts", "../../../conformance/bundles/**/*.steps.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts", "../../../conformance/bundles/**/*.ts"]
    },
    "packages/language": {
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignoreDependencies": [
        "@tree-sitter-grammars/tree-sitter-kotlin",
        "tree-sitter-c-sharp",
        "tree-sitter-go",
        "tree-sitter-java",
        "tree-sitter-python",
        "tree-sitter-ruby",
        "tree-sitter-rust",
        "tree-sitter-typescript"
      ]
    },
    "packages/lsp": {
      "project": ["src/**/*.ts", "tests/**/*.ts"],
      "ignoreDependencies": [
        "@tree-sitter-grammars/tree-sitter-kotlin",
        "tree-sitter-c-sharp",
        "tree-sitter-go",
        "tree-sitter-java",
        "tree-sitter-python",
        "tree-sitter-ruby",
        "tree-sitter-rust",
        "tree-sitter-typescript"
      ]
    },
    "packages/vscode": {
      "project": ["src/**/*.ts"]
    },
    "../examples/typescript-vitest": {
      "entry": ["steps/*.steps.ts"],
      "project": ["**/*.ts"],
      "ignoreDependencies": ["@varar/core"]
    }
  },
  "ignore": ["**/tests/fixtures/**", "packages/website/drafts/**"]
}
