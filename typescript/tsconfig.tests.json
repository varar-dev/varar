{
  // Type-checks the files the per-package `tsc -p tsconfig.json` builds miss:
  // every package's tests/ (the builds only emit their own src/), plus the
  // root/project config files (var.config.ts, vitest.config.ts, the vitest
  // plugin helper) — none of which belong to any package's src/. noEmit: this
  // is a check, not a build. The website's src is excluded — it has its own
  // Astro/browser toolchain (astro/tsconfigs/strict, DOM libs) — but its plain
  // vitest.config.ts is cheap to check and included below.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "packages/var-config/tests",
    "packages/var-core/tests",
    "packages/var-cli/tests",
    "packages/var-language/tests",
    "packages/var-lsp/tests",
    "packages/var/tests",
    "packages/var-vitest/tests",
    "var.config.ts",
    "vitest.config.ts",
    "vitest.plugins.ts",
    "packages/*/vitest.config.ts",
    "packages/*/var.config.ts"
  ]
}
