---
import { decodeEntities } from '../lib/step-highlight.js'

interface Props {
  // The document identity. Must be a `file:///…` URI. The language is
  // inferred from its extension and the tab label from its basename.
  uri: string
}
const { uri } = Astro.props

// A <File> is authored either as plain content (the default slot *is* the
// document) or as a list of <Version label="…"> children (the first version
// is the initial document; the editor offers a button that cycles through
// the rest). Version children render themselves as data-var-version divs, so
// their presence in the rendered slot is the discriminator.
const html = await Astro.slots.render('default')
const hasVersions = html.includes('data-var-version')
const doc = hasVersions ? undefined : decodeEntities(html.replace(/^\n+/, '').replace(/\n+$/, ''))
---
<div data-var-file data-uri={uri} data-doc={doc} hidden>
  {hasVersions && <Fragment set:html={html} />}
</div>
