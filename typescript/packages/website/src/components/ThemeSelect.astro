---
/**
 * Starlight `ThemeSelect` override: prepends the site's custom header controls
 * next to the built-in dark/light/auto select.
 *
 * - Language selector (TypeScript/Java/Kotlin/Python/Ruby) → `data-lang` on <html>.
 *   Every code example on the site follows it: the interactive editors swap
 *   their step-definition tabs, and static code samples in `<Tabs
 *   syncKey="lang">` groups switch to the matching TabItem.
 * - Palette selector (Jord — the default earthy palette in custom.css — or
 *   Fjord/Ild/Fjeld). The choice lives in `data-palette` on <html>.
 * - Prose font selector (STIX Two Text or Atkinson Hyperlegible) → `data-font-prose`.
 * - Code font selector (JetBrains Mono or Atkinson Hyperlegible Mono) → `data-font-code`.
 *
 * The palette and font selectors are design-exploration tools and render only
 * in dev; production ships the defaults (Jord, STIX, JetBrains Mono). The
 * language selector is functional and renders everywhere.
 *
 * Each choice persists in localStorage (`var-lang` / `var-palette` /
 * `var-font-prose` / `var-font-code`); an inline head script (the
 * var-restore-prefs integration in astro.config.mjs) re-applies them before
 * first paint. The font attributes drive --sl-font / --sl-font-mono via the
 * override rules in custom.css; headings stay on Norse regardless.
 */
import Select from '@astrojs/starlight/components/Select.astro'
import Default from '@astrojs/starlight/components/ThemeSelect.astro'
import LangSelect from './LangSelect.astro'

const dev = import.meta.env.DEV
---

<var-lang-select>
  <LangSelect />
</var-lang-select>
{
  dev && (
    <>
      <var-palette-select>
        <Select
          icon="pencil"
          label="Select palette"
          options={[
            { label: 'Jord', selected: true, value: 'jord' },
            { label: 'Fjord', selected: false, value: 'fjord' },
            { label: 'Ild', selected: false, value: 'ild' },
            { label: 'Fjeld', selected: false, value: 'fjeld' },
          ]}
          width="6.25em"
        />
      </var-palette-select>
      <var-font-select data-font-kind="prose">
        <Select
          icon="open-book"
          label="Select prose font"
          options={[
            { label: 'STIX', selected: true, value: 'stix' },
            { label: 'Atkinson', selected: false, value: 'atkinson' },
          ]}
          width="7em"
        />
      </var-font-select>
      <var-font-select data-font-kind="code">
        <Select
          icon="code-branch"
          label="Select code font"
          options={[
            { label: 'JetBrains', selected: true, value: 'jetbrains' },
            { label: 'Atkinson', selected: false, value: 'atkinson' },
          ]}
          width="7.5em"
        />
      </var-font-select>
    </>
  )
}
<Default><slot /></Default>

<script>
  import {
    currentLang,
    LANG_LABELS,
    langOfLabel,
    onLangChange,
    parseLang,
    setLang,
    type SiteLang,
  } from '../lib/site-lang.ts'

  const LANG_TAB_GROUP = 'starlight-tabs[data-sync-key="lang"]'

  // Flip one Starlight tab group to the tab whose label matches — the same
  // DOM surgery Starlight's own inline restore script performs, so it neither
  // steals focus nor scrolls the page the way a synthetic tab.click() would.
  function switchLangTabGroup(group: Element, label: string): void {
    const tabs = [...group.querySelectorAll('[role="tab"]')]
    const panels = [...group.querySelectorAll(':scope > [role="tabpanel"]')]
    const index = tabs.findIndex((tab) => tab.textContent?.trim() === label)
    if (index < 0) return
    tabs.forEach((tab, i) => {
      tab.setAttribute('aria-selected', String(i === index))
      if (i === index) tab.removeAttribute('tabindex')
      else tab.setAttribute('tabindex', '-1')
    })
    panels.forEach((panel, i) => {
      if (i === index) panel.removeAttribute('hidden')
      else panel.setAttribute('hidden', 'true')
    })
  }

  /** Keep every language select and every synced lang tab group showing `lang`. */
  function syncLangUi(lang: SiteLang): void {
    document.querySelectorAll<HTMLSelectElement>('var-lang-select select').forEach((select) => {
      select.value = lang
    })
    for (const group of document.querySelectorAll(LANG_TAB_GROUP)) {
      switchLangTabGroup(group, LANG_LABELS[lang])
    }
  }

  onLangChange((lang) => {
    syncLangUi(lang)
    // Feed Starlight's own persistence too, so its inline restore script
    // selects the right tab before first paint on the next page — even when
    // this page had no lang tab group to click.
    try {
      localStorage.setItem('starlight-synced-tabs__lang', LANG_LABELS[lang])
    } catch {
      /* private mode */
    }
  })

  // The reverse direction: choosing a language by clicking a synced code tab
  // moves the dropdown (and the editors) too. Keyboard tab switching
  // (arrow keys) bypasses click, so watch both and read the group's selected
  // tab after Starlight's own handler has run.
  function bridgeTabToDropdown(target: EventTarget | null): void {
    if (!(target instanceof Element)) return
    const group = target.closest(LANG_TAB_GROUP)
    if (!group) return
    queueMicrotask(() => {
      const selected = group.querySelector('[role="tab"][aria-selected="true"]')
      const lang = langOfLabel(selected?.textContent?.trim() ?? '')
      if (lang) setLang(lang)
    })
  }
  document.addEventListener('click', (e) => bridgeTabToDropdown(e.target))
  document.addEventListener('keydown', (e) => bridgeTabToDropdown(e.target))

  class VarLangSelect extends HTMLElement {
    constructor() {
      super()
      syncLangUi(currentLang())
      this.querySelector('select')?.addEventListener('change', (e) => {
        if (e.currentTarget instanceof HTMLSelectElement) {
          setLang(parseLang(e.currentTarget.value))
        }
      })
    }
  }
  customElements.define('var-lang-select', VarLangSelect)

  type Palette = 'jord' | 'fjord' | 'ild' | 'fjeld'

  // Font selectors — prose (--sl-font) and code (--sl-font-mono). Each swaps
  // its default family for Atkinson Hyperlegible via a data-* attribute on
  // <html>; the actual font-family values live in custom.css.
  type FontKind = 'prose' | 'code'

  interface FontConfig {
    storageKey: string
    attr: 'fontProse' | 'fontCode'
    alt: string
    fallback: string
  }

  // The palette/font selects render only in dev; Vite strips this whole block
  // from production bundles.
  if (import.meta.env.DEV) {
    const storageKey = 'var-palette'

    const parsePalette = (value: unknown): Palette =>
      value === 'fjord' || value === 'ild' || value === 'fjeld' ? value : 'jord'

    const loadPalette = (): Palette =>
      parsePalette(typeof localStorage !== 'undefined' && localStorage.getItem(storageKey))

    function storePalette(palette: Palette): void {
      if (typeof localStorage !== 'undefined') {
        localStorage.setItem(storageKey, palette)
      }
    }

    /** Update <html>, and keep every palette select (header + mobile menu) in sync. */
    function applyPalette(palette: Palette): void {
      document.documentElement.dataset.palette = palette
      document
        .querySelectorAll<HTMLSelectElement>('var-palette-select select')
        .forEach((select) => {
          select.value = palette
        })
    }

    class VarPaletteSelect extends HTMLElement {
      constructor() {
        super()
        applyPalette(loadPalette())
        this.querySelector('select')?.addEventListener('change', (e) => {
          if (e.currentTarget instanceof HTMLSelectElement) {
            const palette = parsePalette(e.currentTarget.value)
            applyPalette(palette)
            storePalette(palette)
          }
        })
      }
    }
    customElements.define('var-palette-select', VarPaletteSelect)

    const FONTS: Record<FontKind, FontConfig> = {
      prose: { storageKey: 'var-font-prose', attr: 'fontProse', alt: 'atkinson', fallback: 'stix' },
      code: {
        storageKey: 'var-font-code',
        attr: 'fontCode',
        alt: 'atkinson',
        fallback: 'jetbrains',
      },
    }

    const parseFont = (kind: FontKind, value: unknown): string =>
      value === FONTS[kind].alt ? FONTS[kind].alt : FONTS[kind].fallback

    const loadFont = (kind: FontKind): string =>
      parseFont(
        kind,
        typeof localStorage !== 'undefined' && localStorage.getItem(FONTS[kind].storageKey),
      )

    function storeFont(kind: FontKind, value: string): void {
      if (typeof localStorage !== 'undefined') {
        localStorage.setItem(FONTS[kind].storageKey, value)
      }
    }

    /** Update <html>, and keep both matching font selects (header + mobile menu) in sync. */
    function applyFont(kind: FontKind, value: string): void {
      document.documentElement.dataset[FONTS[kind].attr] = value
      document
        .querySelectorAll<HTMLSelectElement>(`var-font-select[data-font-kind="${kind}"] select`)
        .forEach((select) => {
          select.value = value
        })
    }

    class VarFontSelect extends HTMLElement {
      constructor() {
        super()
        const kind = this.dataset.fontKind
        if (kind !== 'prose' && kind !== 'code') return
        applyFont(kind, loadFont(kind))
        this.querySelector('select')?.addEventListener('change', (e) => {
          if (e.currentTarget instanceof HTMLSelectElement) {
            const value = parseFont(kind, e.currentTarget.value)
            applyFont(kind, value)
            storeFont(kind, value)
          }
        })
      }
    }
    customElements.define('var-font-select', VarFontSelect)
  }
</script>
