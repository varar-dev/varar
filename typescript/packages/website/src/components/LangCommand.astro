---
/**
 * A `<Tabs syncKey="lang">` group showing one command per language, driven by
 * the shared `languages.json` manifest so the install/run commands on the docs
 * never drift from what each port actually ships. Because it uses the
 * site-wide `lang` sync key, every group on the page — and the header language
 * dropdown — move together.
 *
 * `kind` picks which command to show. The scaffold step (`varar init`, or the
 * hand-written setup for ports without a CLI) is richer than one command and
 * lives in `LangConfigure.astro`.
 */
import { Code, TabItem, Tabs } from '@astrojs/starlight/components'
import { LANGUAGES } from '../lib/site-lang'

interface Props {
  kind: 'install' | 'run'
}

const { kind } = Astro.props
---

<Tabs syncKey="lang">
  {
    LANGUAGES.map((lang) => {
      const block = lang[kind]
      return (
        <TabItem label={lang.label}>
          <Code code={block.code} lang={block.lang} />
        </TabItem>
      )
    })
  }
</Tabs>
