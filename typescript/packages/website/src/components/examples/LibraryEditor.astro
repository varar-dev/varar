---
import Editor from '$components/Editor.astro'
import File from '$components/File.astro'
import Version from '$components/Version.astro'
import libraryLogicCsharp from '$examples/csharp-vstest/src/Library.cs?raw'
import libraryStepsCsharp from '$examples/csharp-vstest/steps/library.steps.cs?raw'
import libraryLogicGo from '$examples/go-gotest/library.go?raw'
import libraryStepsGo from '$examples/go-gotest/library.steps.go?raw'
import libraryLogicJava from '$examples/java-junit-maven/src/main/java/examples/Library.java?raw'
import libraryStepsJava from '$examples/java-junit-maven/src/test/java/varar/LibrarySteps.java?raw'
import libraryLogicKotlin from '$examples/kotlin-junit/src/main/kotlin/examples/Library.kt?raw'
import libraryStepsKotlin from '$examples/kotlin-junit/src/test/kotlin/varar/library.steps.kt?raw'
import libraryLogicPython from '$examples/python-pytest/src/library_example/__init__.py?raw'
import libraryStepsPython from '$examples/python-pytest/tests/varar/library.steps.py?raw'
import libraryLogicRuby from '$examples/ruby-rspec/lib/library.rb?raw'
import libraryStepsRuby from '$examples/ruby-rspec/spec/varar/library.steps.rb?raw'
import libraryLogicRust from '$examples/rust-cargotest/src/library.rs?raw'
import libraryStepsRust from '$examples/rust-cargotest/src/varar/library.steps.rs?raw'
import libraryLogicTypeScript from '$examples/typescript-vitest/src/library.ts?raw'
import libraryStepsTypeScript from '$examples/typescript-vitest/src/varar/library.steps.ts?raw'
import librarySource from '$examples/typescript-vitest/varar/library.md?raw'
---
<Editor>
  <File uri="file:///library.md">
    <Version label="Fix it">{librarySource}</Version>
    <Version label="Break it">{librarySource.replace('£2.50', '£3.00').replace('the library agrees', 'the library refuses')}</Version>
    <Version label="Reword (drift)">{librarySource.replace('due back on June 12', 'due on June 12').replace('asks to borrow *Hyperion*', 'wants to borrow *Hyperion*').replace('the library agrees', 'the library says yes')}</Version>
  </File>
  <File uri="file:///steps/library.steps.ts">{libraryStepsTypeScript}</File>
  <File uri="file:///src/library.ts">{libraryLogicTypeScript}</File>
  <File uri="file:///library.steps.cs">{libraryStepsCsharp}</File>
  <File uri="file:///Library.cs">{libraryLogicCsharp}</File>
  <File uri="file:///library.steps.go">{libraryStepsGo}</File>
  <File uri="file:///library_domain.go">{libraryLogicGo}</File>
  <File uri="file:///LibrarySteps.java">{libraryStepsJava}</File>
  <File uri="file:///Library.java">{libraryLogicJava}</File>
  <File uri="file:///library.steps.kt">{libraryStepsKotlin}</File>
  <File uri="file:///Library.kt">{libraryLogicKotlin}</File>
  <File uri="file:///library.steps.py">{libraryStepsPython}</File>
  <File uri="file:///library_example.py">{libraryLogicPython}</File>
  <File uri="file:///library.steps.rb">{libraryStepsRuby}</File>
  <File uri="file:///library.rb">{libraryLogicRuby}</File>
  <File uri="file:///library.steps.rs">{libraryStepsRust}</File>
  <File uri="file:///library.rs">{libraryLogicRust}</File>
</Editor>
