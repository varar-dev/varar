---
import Editor from '$components/Editor.astro'
import File from '$components/File.astro'
import Version from '$components/Version.astro'
import deepThoughtStepsJava from '$examples/java-junit-maven/src/test/java/examples/DeepThoughtSteps.java?raw'
import deepThoughtStepsKotlin from '$examples/kotlin-junit/src/test/kotlin/examples/deep-thought.steps.kt?raw'
import deepThoughtStepsPython from '$examples/python-pytest/steps/deep_thought.steps.py?raw'
import deepThoughtStepsRuby from '$examples/ruby-rspec/steps/deep_thought.steps.rb?raw'
import deepThoughtStepsRust from '$examples/rust-cargotest/src/steps/deep_thought.rs?raw'
import deepThoughtSource from '$examples/typescript-vitest/deep-thought.md?raw'
import deepThoughtStepsTypeScript from '$examples/typescript-vitest/steps/deep-thought.steps.ts?raw'
---
<Editor>
  <File uri="file:///deep-thought.md">
    <Version label="Fix it">{deepThoughtSource}</Version>
    <Version label="Break it">{deepThoughtSource.replace('42', '41')}</Version>
  </File>
  <File uri="file:///deep-thought.steps.ts">
    <Version label="Fix it">{deepThoughtStepsTypeScript}</Version>
    <Version label="Break it">{deepThoughtStepsTypeScript.replace('42', '43')}</Version>
  </File>
  <File uri="file:///DeepThoughtSteps.java">{deepThoughtStepsJava}</File>
  <File uri="file:///deep-thought.steps.kt">{deepThoughtStepsKotlin}</File>
  <File uri="file:///deep_thought.steps.py">{deepThoughtStepsPython}</File>
  <File uri="file:///deep_thought.steps.rb">{deepThoughtStepsRuby}</File>
  <File uri="file:///deep_thought.rs">{deepThoughtStepsRust}</File>
</Editor>
