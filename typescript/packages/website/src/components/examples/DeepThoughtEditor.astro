---
import Editor from '$components/Editor.astro'
import File from '$components/File.astro'
import Version from '$components/Version.astro'
import deepThoughtStepsCsharp from '$examples/csharp-vstest/steps/deep-thought.steps.cs?raw'
import deepThoughtStepsGo from '$examples/go-gotest/deep_thought.steps.go?raw'
import deepThoughtStepsJava from '$examples/java-junit-maven/src/test/java/varar/DeepThoughtSteps.java?raw'
import deepThoughtStepsKotlin from '$examples/kotlin-junit/src/test/kotlin/varar/deep-thought.steps.kt?raw'
import deepThoughtStepsPython from '$examples/python-pytest/tests/varar/deep_thought.steps.py?raw'
import deepThoughtStepsRuby from '$examples/ruby-rspec/spec/varar/deep_thought.steps.rb?raw'
import deepThoughtStepsRust from '$examples/rust-cargotest/src/varar/deep_thought.steps.rs?raw'
import deepThoughtStepsTypeScript from '$examples/typescript-vitest/src/varar/deep-thought.steps.ts?raw'
import deepThoughtSource from '$examples/typescript-vitest/varar/deep-thought.md?raw'
---
<Editor>
  <File uri="file:///deep-thought.md">
    <Version label="Fix it">{deepThoughtSource}</Version>
    <Version label="Break it">{deepThoughtSource.replace('42', '41')}</Version>
  </File>
  <File uri="file:///deep-thought.steps.ts">
    <Version label="Fix it">{deepThoughtStepsTypeScript}</Version>
    <Version label="Break it">{deepThoughtStepsTypeScript.replace('42', '43')}</Version>
  </File>
  <File uri="file:///deep-thought.steps.cs">{deepThoughtStepsCsharp}</File>
  <File uri="file:///deepthought.steps.go">{deepThoughtStepsGo}</File>
  <File uri="file:///DeepThoughtSteps.java">{deepThoughtStepsJava}</File>
  <File uri="file:///deep-thought.steps.kt">{deepThoughtStepsKotlin}</File>
  <File uri="file:///deep_thought.steps.py">{deepThoughtStepsPython}</File>
  <File uri="file:///deep_thought.steps.rb">{deepThoughtStepsRuby}</File>
  <File uri="file:///deep_thought.steps.rs">{deepThoughtStepsRust}</File>
</Editor>
