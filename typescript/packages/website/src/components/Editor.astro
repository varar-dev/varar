---
import { langOfPath, SITE_LANGS, type SiteLang } from '../lib/site-lang'

interface Props {
  // Show the line-number gutter for every File tab (default false).
  lineNumbers?: boolean
  // Show the fold (collapse/expand) gutter for every File tab (default false).
  folding?: boolean
  // Offer the "Define step definition" affordance on a settled selection in
  // markdown File tabs (default true).
  define?: boolean
  // Milliseconds between keystrokes when a version button replays its edits.
  // Lower is faster. Only relevant for a File with ≥2 <Version> children.
  replayMs?: number
  // The languages this editor must carry a code <File> for. Defaults to every
  // site language, so adding a port to languages.json turns any <Editor> that
  // forgot its files into a build error (see the completeness check below).
  // Narrow it only for an editor that deliberately shows a subset.
  langs?: ReadonlyArray<SiteLang>
}
const {
  lineNumbers = false,
  folding = false,
  define = true,
  replayMs = 100,
  langs = SITE_LANGS,
} = Astro.props

// Render the <File> children once so we can both check them and emit them.
// Every File renders a `data-uri`; its extension maps to a SiteLang (or to
// undefined for the language-neutral .md oath). A required language with no
// tab would fall back silently at runtime (see editor-mount.ts) — here it
// fails `astro build` instead, so a new port can't ship with empty examples.
const slotHtml = await Astro.slots.render('default')
const present = new Set<SiteLang>(
  [...slotHtml.matchAll(/data-uri="([^"]*)"/g)]
    .map((m) => langOfPath(m[1]))
    .filter((lang): lang is SiteLang => lang !== undefined),
)
const missing = langs.filter((lang) => !present.has(lang))
if (missing.length > 0) {
  throw new Error(
    `<Editor> is missing example files for: ${missing.join(', ')}. ` +
      'Add a <File uri="…"> whose extension maps to each missing language ' +
      '(the extensions live in languages.json).',
  )
}
---
<!--
  not-content opts the whole subtree out of Starlight's sibling-spacing rule
  (`.sl-markdown-content :not(…) + :not(…) { margin-top: … }`), which would
  otherwise push every tab after the first down and misalign the tab row.
-->
<figure class="file-editor not-content my-6">
  <figcaption
    class="fe-tabs flex items-center gap-1 px-[6px] pt-[6px] border-b border-line-subtle"
    role="tablist"
  ></figcaption>
  <div
    class="cm-mount relative m-0 border border-t-0 border-line-subtle rounded-none overflow-hidden"
    data-line-numbers={String(lineNumbers)}
    data-folding={String(folding)}
    data-define={String(define)}
    data-replay-ms={String(replayMs)}
  ></div>
  <div hidden set:html={slotHtml} />
</figure>
<style>
  /*
   * line-height: CodeMirror never sets its own — it measures whatever's
   * inherited at mount time and caches that for its vertical-motion math
   * (cursorLineDown/Up, scrollIntoView). Starlight's own reset sets
   * `body { line-height: 1.75 }` for prose, which this component would
   * otherwise inherit — both the visibly loose leading and (if that
   * measurement races the variable font finishing loading and going
   * stale) the ArrowUp/ArrowDown skipping a line. Pin it explicitly so
   * the editor never depends on an ambient page-level value.
   */
  .cm-mount :global(.cm-editor) { font-size: 15px; line-height: normal; }
  .cm-mount :global(.cm-editor.cm-focused) { outline: none; }
</style>
<script>
  import '../scripts/editor-mount.ts'
</script>
