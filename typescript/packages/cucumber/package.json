{
  "name": "@oselvar/cucumber",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS=\"--import tsx\" cucumber-js && pnpm test:var && pnpm test:var-vitest",
    "test:cucumber": "NODE_OPTIONS=\"--import tsx\" cucumber-js",
    "test:var": "NODE_OPTIONS=\"--import tsx\" node ../var-cli/src/bin.ts run",
    "test:var-vitest": "NODE_OPTIONS=\"--import tsx\" vitest run"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@oselvar/var": "workspace:*",
    "@oselvar/var-cli": "workspace:*",
    "@oselvar/var-core": "workspace:*",
    "@oselvar/var-vitest": "workspace:*",
    "@types/node": "^26.1.0",
    "tsx": "^4.22.5",
    "vitest": "^4.1.9"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oselvar/var.git",
    "directory": "typescript/packages/cucumber"
  }
}
