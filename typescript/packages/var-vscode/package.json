{
  "name": "oselvar-var",
  "displayName": "Vár",
  "description": "Markdown-native BDD: highlight matched steps, go-to step definitions, missing-step diagnostics.",
  "publisher": "oselvar",
  "version": "0.4.2",
  "type": "module",
  "engines": {
    "vscode": "^1.105.0",
    "node": ">=22"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Testing"
  ],
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:typescript",
    "onLanguage:python",
    "onLanguage:java",
    "onLanguage:kotlin",
    "workspaceContains:**/var.config.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "oselvar-var.generateStepDefinition",
        "title": "BDD: Generate Step Definition from Selection",
        "category": "BDD"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "oselvar-var.generateStepDefinition",
          "when": "editorHasSelection && resourceExtname == .md",
          "group": "var@1"
        }
      ],
      "commandPalette": [
        {
          "command": "oselvar-var.generateStepDefinition",
          "when": "editorHasSelection"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node esbuild.mjs"
  },
  "dependencies": {
    "@oselvar/var-lsp": "workspace:*",
    "vscode-languageclient": "^10.1.0"
  },
  "devDependencies": {
    "@types/vscode": "~1.125.0",
    "esbuild": "^0.28.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oselvar/var.git",
    "directory": "typescript/packages/var-vscode"
  },
  "private": true
}
