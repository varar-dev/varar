{
  "name": "varar-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.18"
  },
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "build": "pnpm -r --filter '!@varar/website' --filter '!@varar/website' build",
    "typecheck": "tsc -p tsconfig.tests.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check . && node scripts/lint-no-reexports.mjs",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "knip": "knip",
    "jscpd": "jscpd packages",
    "install:vscode": "pnpm -r --filter @varar/lsp --filter varar build && node scripts/install-vscode.mjs",
    "check": "pnpm lint:fix && pnpm typecheck && pnpm test:coverage && pnpm knip && pnpm jscpd"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "jscpd": "^5.0.11",
    "knip": "^6.25.0",
    "typescript": "^7.0.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
