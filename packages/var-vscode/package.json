{
  "name": "oselvar-var",
  "displayName": "Vár",
  "description": "Markdown-native BDD: highlight matched steps, go-to step definitions, missing-step diagnostics.",
  "publisher": "oselvar",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "vscode": "^1.92.0",
    "node": ">=22"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Testing"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:typescript",
    "workspaceContains:**/var.config.ts",
    "workspaceContains:**/*.var.md"
  ],
  "contributes": {
    "languages": [
      {
        "id": "var-markdown",
        "aliases": [
          "Vár Markdown",
          "var-md"
        ],
        "extensions": [
          ".var.md"
        ]
      }
    ],
    "commands": [
      {
        "command": "oselvar-var.generateStepDefinition",
        "title": "BDD: Generate Step Definition from Selection",
        "category": "BDD"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "oselvar-var.generateStepDefinition",
          "when": "editorHasSelection && resourceExtname == .md",
          "group": "var@1"
        }
      ],
      "commandPalette": [
        {
          "command": "oselvar-var.generateStepDefinition",
          "when": "editorHasSelection"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@oselvar/var-language": "workspace:*",
    "@oselvar/var-lsp": "workspace:*",
    "vscode-languageclient": "^10.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0"
  }
}
