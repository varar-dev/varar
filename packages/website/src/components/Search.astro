---
import Search from 'astro-pagefind/components/Search.astro'
---

<Search
  className="docs-search"
  searchboxOptions={{ placeholder: 'Search docs…' }}
/>

<style is:global>
  .docs-search {
    display: contents;
  }
  .docs-search pagefind-searchbox {
    width: 100%;
    max-width: 28rem;
  }
  .docs-search .pagefind-ui__search-input,
  pagefind-searchbox::part(input) {
    background: var(--cream);
    border: 2px solid var(--ink);
    border-radius: var(--radius-5);
    font-size: 14px;
  }
  pagefind-searchbox::part(results) {
    z-index: 70;
  }
</style>
