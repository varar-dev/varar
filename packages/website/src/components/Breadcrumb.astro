---
interface Props {
  base: string
  area?: string
  title?: string
}
const { base, area, title } = Astro.props
---

<nav class="text-sm text-subtle mb-6" aria-label="Breadcrumb">
  <a class="text-ink no-underline hover:underline" href={`${base}/`}>Vár</a>
  <span class="text-subtle mx-1" aria-hidden="true">›</span>
  <a class="text-ink no-underline hover:underline" href={`${base}/docs/`}>docs</a>
  {area && (
    <>
      <span class="text-subtle mx-1" aria-hidden="true">›</span>
      <span>{area}</span>
    </>
  )}
  {title && (
    <>
      <span class="text-subtle mx-1" aria-hidden="true">›</span>
      <span aria-current="page">{title}</span>
    </>
  )}
</nav>
