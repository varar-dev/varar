---
// Aksel-style copy-to-clipboard button for fenced code blocks.
// https://aksel.nav.no/komponenter/core/copybutton
//
// Rendered once per docs page. The script enhances every <pre> inside
// `.doc-body` (skipping the FileEditor code windows) with a copy button that
// follows the Aksel CopyButton behaviour: a Files icon that swaps to a
// Checkmark + "Copied!" label for 2s after a successful copy.
---

<template id="copybtn-template">
  <button class="copybtn" type="button" aria-label="Copy" title="Copy">
    <svg class="copybtn__icon copybtn__icon--copy" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path fill-rule="evenodd" clip-rule="evenodd" d="M8.25 3.5C8.25 2.80964 8.80964 2.25 9.5 2.25H14C14.1989 2.25 14.3897 2.32902 14.5303 2.46967L19.5303 7.46967C19.671 7.61032 19.75 7.80109 19.75 8V16.5C19.75 17.1904 19.1904 17.75 18.5 17.75H9.5C8.80964 17.75 8.25 17.1904 8.25 16.5V3.5ZM14.5 8.75C13.8096 8.75 13.25 8.19036 13.25 7.5V3.75H9.75V16.25H18.25V8.75H14.5ZM14.75 4.81066L17.1893 7.25H14.75V4.81066ZM6.50182 7.75H5.75V20.25H14.25V19.5022C14.25 19.088 14.5858 18.7522 15 18.7522C15.4142 18.7522 15.75 19.088 15.75 19.5022V20.5C15.75 21.1904 15.1904 21.75 14.5 21.75H5.5C4.80964 21.75 4.25 21.1904 4.25 20.5V7.5C4.25 6.80964 4.80964 6.25 5.5 6.25H6.50182C6.91604 6.25 7.25182 6.58579 7.25182 7C7.25182 7.41421 6.91604 7.75 6.50182 7.75Z" fill="currentColor"></path>
    </svg>
    <svg class="copybtn__icon copybtn__icon--check" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path fill-rule="evenodd" clip-rule="evenodd" d="M18.9983 6.93945C19.3079 7.21464 19.3357 7.68869 19.0606 7.99828L11.0606 16.9983C10.9233 17.1527 10.7285 17.2436 10.522 17.2497C10.3156 17.2558 10.1157 17.1764 9.96967 17.0303L4.96967 12.0303C4.67678 11.7374 4.67678 11.2626 4.96967 10.9697C5.26256 10.6768 5.73744 10.6768 6.03033 10.9697L10.4679 15.4072L17.9394 7.00174C18.2146 6.69215 18.6887 6.66426 18.9983 6.93945Z" fill="currentColor"></path>
    </svg>
  </button>
</template>

<style is:global>
  .doc-body .code-block {
    position: relative;
  }
  .copybtn {
    position: absolute;
    top: var(--ax-space-8, 8px);
    right: var(--ax-space-8, 8px);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: 1px solid var(--ax-border-subtle);
    border-radius: var(--ax-radius-8, 8px);
    background: var(--ax-bg-default);
    color: var(--ax-text-subtle);
    cursor: pointer;
    opacity: 0;
    transition:
      opacity 0.12s ease,
      color 0.12s ease,
      background 0.12s ease;
  }
  .doc-body .code-block:hover .copybtn,
  .copybtn:focus-visible,
  .copybtn.copybtn--active {
    opacity: 1;
  }
  .copybtn:hover {
    color: var(--ax-text-default);
    background: var(--ax-bg-raised);
  }
  .copybtn__icon {
    width: 1.15rem;
    height: 1.15rem;
  }
  .copybtn__icon--check {
    display: none;
  }
  .copybtn--active {
    color: var(--ax-text-default);
  }
  .copybtn--active .copybtn__icon--copy {
    display: none;
  }
  .copybtn--active .copybtn__icon--check {
    display: inline;
  }
  /* No hover on touch devices — keep the button visible. */
  @media (hover: none) {
    .copybtn {
      opacity: 1;
    }
  }
</style>

<script>
  function enhanceCodeBlocks() {
    const tpl = document.getElementById('copybtn-template') as HTMLTemplateElement | null
    if (!tpl) return
    const blocks = document.querySelectorAll<HTMLPreElement>('.doc-body pre:not([data-copy])')
    for (const pre of blocks) {
      pre.setAttribute('data-copy', '')
      // Skip the FileEditor code windows — only real fenced code blocks.
      if (pre.closest('.file-editor')) continue

      const wrap = document.createElement('div')
      wrap.className = 'code-block'
      pre.parentNode?.insertBefore(wrap, pre)
      wrap.appendChild(pre)

      const btn = tpl.content.firstElementChild?.cloneNode(true) as HTMLButtonElement | undefined
      if (!btn) continue
      wrap.appendChild(btn)

      let timer: ReturnType<typeof setTimeout> | undefined
      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code')
        const text = (code?.innerText ?? pre.innerText).replace(/\n+$/, '')
        try {
          await navigator.clipboard.writeText(text)
        } catch {
          return
        }
        btn.classList.add('copybtn--active')
        btn.setAttribute('aria-label', 'Copied!')
        btn.setAttribute('title', 'Copied!')
        clearTimeout(timer)
        timer = setTimeout(() => {
          btn.classList.remove('copybtn--active')
          btn.setAttribute('aria-label', 'Copy')
          btn.setAttribute('title', 'Copy')
        }, 2000)
      })
    }
  }

  enhanceCodeBlocks()
  document.addEventListener('astro:after-swap', enhanceCodeBlocks)
</script>
