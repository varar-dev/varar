---
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<footer class="border-t border-line-subtle px-6 py-8 mt-16 flex flex-wrap gap-4 items-center justify-between text-sm text-subtle">
  <nav class="flex gap-5 flex-wrap" aria-label="Footer">
    <a class="text-ink no-underline hover:underline" href={`${base}/docs/`}>Docs</a>
    <a class="text-ink no-underline hover:underline" href={`${base}/blog/`}>Blog</a>
    <a class="text-ink no-underline hover:underline" href={`${base}/playground`}>Playground</a>
    <a class="text-ink no-underline hover:underline" href="https://github.com/oselvar/var">GitHub</a>
  </nav>
  <p class="m-0">© 2026 Oselvar</p>
</footer>
