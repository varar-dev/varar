---
import { decodeEntities } from '../lib/step-highlight.js'

interface Props {
  // The document identity. Must be a `file:///…` URI. The language is inferred
  // from its extension and the header filename (see `chrome`) from its basename.
  uri: string
  // Show the line-number gutter (default false).
  lineNumbers?: boolean
  // Show the fold (collapse/expand) gutter (default false).
  folding?: boolean
  // Offer the "Define step definition" affordance on a settled selection
  // (default false). Markdown editors only.
  define?: boolean
  // Render a borderless header bar (filename derived from `uri`) directly above
  // the editor (default false). The editor itself looks identical without it.
  chrome?: boolean
  // Editors sharing a group run together; their specs run against the step
  // files in the same group. Omit to use the page-wide default group.
  group?: string
  // Hidden companion step sources fed to this editor's run group without
  // rendering a visible editor. Use when a doc shows only the spec.
  steps?: ReadonlyArray<{ path: string; source: string }>
}
const {
  uri,
  lineNumbers = false,
  folding = false,
  define = false,
  chrome = false,
  group,
  steps,
} = Astro.props

// Language is inferred from the uri extension: TypeScript for `.ts` (incl.
// `.steps.ts`), Markdown otherwise (`.md`, `.var.md`).
const lang = uri.endsWith('.ts') ? 'typescript' : 'markdown'

// The header filename is the uri's basename (strip the file:// scheme and any
// directory) — shown only when `chrome` is set.
const filename = uri.replace(/^file:\/\//, '').replace(/^.*\//, '')

// The document is the default slot. Author it as a raw string child —
// `<Editor uri="…">{`line one\nline two`}</Editor>` — so MDX/Astro passes the
// text through verbatim. The rendered slot is HTML-escaped, so decode it back
// to the raw source before handing it to CodeMirror via `data-doc`.
const doc = decodeEntities(
  (await Astro.slots.render('default')).replace(/^\n+/, '').replace(/\n+$/, ''),
)

const mountAttrs = {
  class: 'cm-mount',
  'data-uri': uri,
  'data-lang': lang,
  'data-doc': doc,
  'data-line-numbers': String(lineNumbers),
  'data-folding': String(folding),
  'data-define': String(define),
  'data-group': group,
  'data-steps': steps ? JSON.stringify(steps) : undefined,
}
---
{chrome ? (
  <figure class="file-editor">
    <figcaption class="fe-bar">{filename}</figcaption>
    <div {...mountAttrs}></div>
  </figure>
) : (
  <div {...mountAttrs}></div>
)}
<style>
  .cm-mount { border: 1px solid var(--ax-border-subtle); border-radius: var(--radius-5); overflow: hidden; margin: 24px 0; }
  .cm-mount :global(.cm-editor) { font-size: 14px; }
  .cm-mount :global(.cm-editor.cm-focused) { outline: none; }

  /* Filename variant — shown only when `filename` is set. A borderless header
     bar (background = the editor's border colour, text = the heading ink) sits
     directly above the otherwise-unchanged bare editor. No window chrome,
     shadow, or hover; the nested mount only drops its own vertical margin. */
  .file-editor {
    margin: 24px 0;
  }
  .file-editor .cm-mount {
    margin: 0;
  }
  .fe-bar {
    padding: 8px 14px;
    background: var(--ax-border-subtle);
    color: var(--ink);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
</style>
<script>
  import '../scripts/editor-mount.ts'
</script>
