---
import yahtzeeSpecBroken from '../../../../docs/tutorial/04-yahtzee.broken.md?raw'
import yahtzeeSpec from '../../../../docs/tutorial/04-yahtzee.md?raw'
import yahtzeeSteps from '../../../../docs/tutorial/steps/04-yahtzee.steps.ts?raw'
import Editor from '../components/Editor.astro'
import Base from '../layouts/Base.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<Base
  title="Vár — Behaviour-Driven Development that doesn’t make you cry"
  description="Vár turns plain-English examples into runnable specs. Discover misunderstandings, clear your head."
>
  <main class="landing max-w-280 mx-auto px-12 pt-20 pb-20">
    <section class="text-center pt-12 pb-6">
      <div class="flex items-center justify-center gap-[clamp(12px,3vw,40px)]">
        <img
          class="h-[clamp(72px,16vw,200px)] w-auto"
          src={`${base}/logo2-transparent.png`}
          alt="Vár logo"
        />
        <h1
          class="font-sans font-semibold text-[clamp(72px,18vw,220px)] leading-[0.95] tracking-[0.02em] m-0 text-ink"
        >
          Vár
        </h1>
      </div>

      <p
        class="mt-4 mb-0 text-[clamp(20px,3.2vw,34px)] font-semibold text-subtle"
      >
        Executable documentation for people and agents
      </p>
    </section>

    <section
      class="grid grid-cols-[minmax(0,1fr)_minmax(0,1fr)] gap-10 items-start pt-6 pb-12 max-[880px]:grid-cols-1 max-[880px]:gap-6"
      aria-label="What Vár is, and a live example"
    >
      <div>
        <p class="max-w-2xl mt-4 mx-auto text-[17px]">
          Vár turns any markdown document into automated tests. Your documentation
          becomes both a <a href="#">guide and a sensor</a>, making it the
          source of truth for your software.
        </p>

        <p class="max-w-2xl mt-4 mx-auto text-center text-[17px] text-subtle">
          <img
            class="h-[clamp(72px,16vw,200px)] w-auto"
            src={`${base}/guide-sensor.svg`}
            alt="Vár logo"
          />
        </p>
      </div>

      <section class="p-0" aria-label="See it live">
        <Editor
          uri="file:///yahtzee.md"
          steps={[{ path: "file:///yahtzee.steps.ts", source: yahtzeeSteps }]}
          chrome
        >
          <Fragment slot="passing">{yahtzeeSpec}</Fragment>
          <Fragment slot="failing">{yahtzeeSpecBroken}</Fragment>
        </Editor>
        <p class="text-center mt-4">
          <a
            class="text-ink underline decoration-accent"
            href={`${base}/playground`}>Open it in the playground →</a>
        </p>
      </section>
    </section>

    <section
      class="flex flex-wrap gap-4 items-center justify-center mt-2 mb-6"
      aria-label="Get started"
    >
      <a
        class="bg-strong text-accent-contrast rounded-none px-6 py-3 font-semibold no-underline hover:bg-strong-hover"
        href={`${base}/docs/start-here/hello-var-your-first-spec`}
        >Get started →</a
      >
      <a
        class="text-ink underline decoration-accent hover:text-ink"
        href={`${base}/docs/`}>Browse docs</a
      >
    </section>
  </main>
</Base>
