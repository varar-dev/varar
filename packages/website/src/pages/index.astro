---
import Base from '../layouts/Base.astro'

const quotes = [
  'Move over vibeslop, here comes Vár',
  'BDD without the BS',
  'Like therapy for your test suite',
  'Specs you’d actually read',
  'Plain English in, working tests out',
  'Your team’s shared brain, in markdown',
]

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<Base
  title="Vár — Behaviour-Driven Development that doesn’t make you cry"
  description="Vár turns plain-English examples into runnable specs. Discover misunderstandings, clear your head."
>
  <main>
    <section class="hero">
      <div class="brand">
        <img class="logo" src={`${base}/logo.svg`} alt="Vár logo" width="1122" height="1402" />
        <h1 class="wordmark">Vár</h1>
      </div>
      <p class="rune" aria-hidden="true">ᚢᛅᚱ</p>
      <p class="tagline">Behaviour-Driven Development for people who hate ceremony.</p>
    </section>

    <section class="pitch" aria-label="What Vár gives you">
      <article>
        <h2>discover misunderstandings</h2>
        <p>
          Pin down what “done” means before anyone writes code. Vár turns plain-English
          examples into runnable specs — the conversation becomes the test.
        </p>
      </article>
      <article>
        <h2>clear your head</h2>
        <p>
          Stop juggling intent in your head. Write the example, run it, and let the tests hold
          the shape of the feature for you.
        </p>
      </article>
    </section>

    <section class="install" aria-label="Install">
      <pre><code>pnpm add -D @oselvar/var-vitest</code></pre>
    </section>

    <section class="quotes" aria-label="Quotes">
      <h2>word on the street</h2>
      <ul>
        {quotes.map((q) => <li>{q}</li>)}
      </ul>
    </section>

    <footer>
      <a href={`${base}/docs/`}>docs</a>
      <span> · </span>
      <a href={`${base}/blog/`}>blog</a>
      <span> · </span>
      <a href="https://github.com/oselvar/var">github.com/oselvar/var</a>
      <span> · © 2026 Oselvar</span>
    </footer>
  </main>
</Base>
