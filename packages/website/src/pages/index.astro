---
import Base from '../layouts/Base.astro'

const quotes = [
  'Move over vibeslop, here comes Vár',
  'BDD without the BS',
  'Like therapy for your test suite',
  'Specs you’d actually read',
  'Plain English in, working tests out',
  'Your team’s shared brain, in markdown',
]

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<Base
  title="Vár — Behaviour-Driven Development that doesn’t make you cry"
  description="Vár turns plain-English examples into runnable specs. Discover misunderstandings, clear your head."
>
  <main>
    <section class="hero">
      <div class="brand">
        <img class="logo" src={`${base}/logo2-transparent.png`} alt="Vár logo" />
        <h1 class="wordmark">Vár</h1>
      </div>
      <p class="rune" aria-hidden="true">ᚢᛅᚱ</p>
      <p class="tagline">Níunda Vár, hon hlýðir á eiða manna ok einkamál, er veita sín á milli konur ok karlar. Því heita þau mál várar. Hon hefnir ok þeim, er brigða.</p>
      <p class="tagline">The ninth is Vár: she harkens to the oaths and compacts made between men and women; wherefore such covenants are called 'vows.' She also takes vengeance on those who perjure themselves.</p>
    </section>

    <section class="cta" aria-label="Get started">
      <a class="cta__primary" href={`${base}/docs/start-here/hello-var-your-first-spec`}>Get started →</a>
      <a class="cta__secondary" href={`${base}/docs/`}>Browse docs</a>
    </section>

    <section class="pitch" aria-label="What Vár gives you">
      <article>
        <h2>discover misunderstandings</h2>
        <p>
          Pin down what “done” means before anyone writes code. Vár turns plain-English
          examples into runnable specs — the conversation becomes the test.
        </p>
      </article>
      <article>
        <h2>clear your head</h2>
        <p>
          Stop juggling intent in your head. Write the example, run it, and let the tests hold
          the shape of the feature for you.
        </p>
      </article>
    </section>

    <section class="install" aria-label="Install">
      <pre><code>pnpm add -D @oselvar/var-vitest</code></pre>
    </section>

    <section class="quotes" aria-label="Quotes">
      <h2>word on the street</h2>
      <ul>
        {quotes.map((q) => <li>{q}</li>)}
      </ul>
    </section>
  </main>
</Base>

<style is:global>
  /*
   * Front-page overrides — these are <style is:global> in index.astro.
   * Astro inlines page global styles BEFORE the linked stylesheet (<link rel="stylesheet">),
   * so we use `main` as a prefix (element specificity bump) to win the cascade over
   * the same-named rules in global.css that load via the linked stylesheet.
   */

  /* ── Hero ── */
  /* Note: keeping responsive clamp for font-size; --ax-font-size-heading-2xlarge (2.5rem/40px)
     would be too small for the hero identity mark next to the logo image */
  main .wordmark {
    font-weight: var(--ax-font-weight-bold);
    color: var(--ax-text-default);
  }

  main .rune {
    color: var(--var-accent);
    opacity: 1;
  }

  main .tagline {
    color: var(--ax-text-subtle);
    max-width: 46rem;
    margin: 16px auto 0;
  }

  /* ── CTA buttons — no global.css competition, no `main` prefix needed ── */
  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--ax-space-16, 16px);
    align-items: center;
    justify-content: center;
    margin: var(--ax-space-8, 8px) 0 var(--ax-space-24, 24px);
  }

  .cta__primary {
    background: var(--ax-bg-accent-strong, var(--var-accent));
    color: var(--ax-text-accent-contrast, #fff);
    border-radius: var(--ax-radius-8);
    padding: var(--ax-space-12) var(--ax-space-24);
    font-weight: var(--ax-font-weight-bold);
    text-decoration: none;
  }

  .cta__primary:hover {
    background: var(--ax-bg-accent-strong-hover, var(--var-accent));
  }

  .cta__secondary {
    color: var(--ax-text-default);
    text-decoration: underline;
    text-decoration-color: var(--var-accent);
  }

  .cta__secondary:hover {
    color: var(--ax-text-default);
  }

  /* ── Pitch ── */
  main .pitch article {
    background: var(--ax-bg-raised);
    border: 1px solid var(--ax-border-subtle);
    border-radius: var(--ax-radius-12);
    padding: var(--ax-space-24);
    color: var(--ax-text-default);
  }

  main .pitch h2 {
    font-size: var(--ax-font-size-heading-medium);
    font-weight: var(--ax-font-weight-bold);
  }

  /* ── Install ── */
  main .install pre {
    background: var(--ax-bg-raised);
    border: 1px solid var(--ax-border-subtle);
    border-radius: var(--ax-radius-12);
    color: var(--ax-text-default);
    padding: var(--ax-space-16) var(--ax-space-24);
  }

  main .install pre::before {
    color: var(--var-accent);
  }

  /* ── Quotes ── */
  main .quotes h2 {
    font-size: var(--ax-font-size-heading-medium);
    font-weight: var(--ax-font-weight-bold);
  }

  main .quotes li {
    background: var(--ax-bg-raised);
    border: 1px solid var(--ax-border-subtle);
    border-radius: var(--ax-radius-12);
    padding: var(--ax-space-20);
    color: var(--ax-text-default);
  }

  main .quotes li::before {
    color: var(--var-accent);
  }
</style>
