---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)
const fmt = (d: Date) => d.toISOString().slice(0, 10)
---

<Base title="Vár blog" description="Notes on Behaviour-Driven Development, executable specs, and Vár.">
  <main class="page">
    <nav class="doc-nav" aria-label="Breadcrumb">
      <a href={`${base}/`}>Vár</a>
      <span aria-hidden="true">›</span>
      <span>blog</span>
    </nav>

    <h1>blog</h1>
    <p class="lede">
      Notes on specs, examples, and not making people cry.
      <a href={`${base}/rss.xml`}>RSS</a>.
    </p>

    <ul class="post-list">
      {posts.map((p) => (
        <li>
          <a class="post-title" href={`${base}/blog/${p.id}/`}>{p.data.title}</a>
          <time datetime={fmt(p.data.pubDate)}>{fmt(p.data.pubDate)}</time>
          <p>{p.data.description}</p>
        </li>
      ))}
    </ul>
  </main>
</Base>

<style>
  .post-list { list-style: none; padding: 0; margin: var(--ax-space-32) 0; }
  .post-list li { padding: var(--ax-space-16) 0; border-bottom: 1px solid var(--ax-border-neutral-subtle); }
  .post-title {
    font-family: var(--ax-font-family);
    font-weight: var(--ax-font-weight-bold);
    font-size: var(--ax-font-size-heading-medium);
    color: var(--ax-text-default);
    text-decoration: none;
  }
  .post-title:hover { color: var(--ax-text-accent, var(--var-accent)); }
  .post-list time { display: block; font-size: 13px; color: var(--ax-text-neutral-subtle); margin: 4px 0; }
  .post-list p { margin: 6px 0 0; }
</style>
