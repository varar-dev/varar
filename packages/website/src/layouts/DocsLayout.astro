---
import Breadcrumb from '../components/Breadcrumb.astro'
import CopyButton from '../components/CopyButton.astro'
import DocsSidebar from '../components/DocsSidebar.astro'
import MoreInArea from '../components/MoreInArea.astro'
import type { Breadcrumb as Crumb, NavGroup, NavLink } from '../lib/docs-nav'
import Base from './Base.astro'

interface Props {
  title: string
  description?: string
  base: string
  groups: ReadonlyArray<NavGroup>
  breadcrumb: Crumb | null
  next?: NavLink | null
}

const { title, description, base, groups, breadcrumb, next } = Astro.props
const fullTitle = `${title} — Vár docs`
const desc = description ?? 'Vár — Behaviour-Driven Development specs an AI agent can work against.'
---

<Base title={fullTitle} description={desc} hasSidebar={true}>
  <div class="docs-shell" data-docs-shell>
    <div class="docs-shell__backdrop" data-docs-backdrop aria-hidden="true"></div>
    <aside class="docs-shell__sidebar" data-docs-sidebar>
      <DocsSidebar groups={groups} />
    </aside>
    <main class="docs-shell__main">
      <Breadcrumb base={base} area={breadcrumb?.area.label} title={breadcrumb?.title} />
      <article class="doc-body prose max-w-none prose-headings:font-semibold prose-h1:text-[1.75rem] prose-h1:leading-[1.05] prose-h2:text-2xl prose-h3:text-xl prose-a:decoration-accent prose-a:decoration-2 prose-a:underline-offset-2" data-pagefind-body>
        <slot />
      </article>
      <MoreInArea next={next} areaLabel={breadcrumb?.area.label} />
    </main>
  </div>
  <CopyButton />

  <style>
    .docs-shell {
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      gap: var(--ax-space-48);
      max-width: 1200px;
      margin: 0 auto;
      padding: var(--ax-space-32) var(--ax-space-24) var(--ax-space-64);
    }
    .docs-shell__backdrop { display: none; }
    .docs-shell__sidebar { position: sticky; top: var(--ax-space-64); align-self: start; max-height: calc(100vh - 5rem); overflow-y: auto; }
    .docs-shell__main { min-width: 0; max-width: 46rem; }

    @media (max-width: 820px) {
      .docs-shell { grid-template-columns: minmax(0, 1fr); }
      .docs-shell__sidebar {
        position: fixed; top: 0; left: 0; bottom: 0; z-index: 60;
        width: 280px; max-height: none; padding: 24px;
        background: var(--ax-bg-default); border-right: 1px solid var(--ax-border-subtle);
        transform: translateX(-100%); transition: transform 0.2s ease;
      }
      .docs-shell.is-open .docs-shell__sidebar { transform: translateX(0); }
      .docs-shell.is-open .docs-shell__backdrop {
        display: block; position: fixed; inset: 0; z-index: 55; background: color-mix(in srgb, var(--ax-text-default) 40%, transparent);
      }
    }
  </style>

  <script>
    function initDocsDrawer() {
      const shell = document.querySelector('[data-docs-shell]')
      const menuEl = document.querySelector<HTMLElement>('[data-docs-menu]')
      const backdrop = document.querySelector('[data-docs-backdrop]')
      const sidebarEl = document.querySelector<HTMLElement>('[data-docs-sidebar]')
      const mainContent = document.querySelector<HTMLElement>('.docs-shell__main')
      const topbar = document.querySelector<HTMLElement>('.topnav')
      if (!shell || !menuEl || !sidebarEl) return
      // After the guard above, these are guaranteed non-null. We reassign to
      // non-nullable locals so closures below can use them without TS complaining.
      const menu: HTMLElement = menuEl
      const sidebar: HTMLElement = sidebarEl

      const mobileQuery = window.matchMedia('(max-width: 820px)')

      // Returns the first focusable element inside the sidebar, or the sidebar itself.
      function firstFocusable(): HTMLElement {
        return (
          sidebar.querySelector<HTMLElement>(
            'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
          ) ?? sidebar
        )
      }

      function applyInertForMobileClosed() {
        if (mobileQuery.matches) {
          sidebar.setAttribute('inert', '')
        } else {
          sidebar.removeAttribute('inert')
        }
        // Always clear main/topbar inert when drawer is not open.
        mainContent?.removeAttribute('inert')
        topbar?.removeAttribute('inert')
      }

      const open = () => {
        shell.classList.add('is-open')
        menu.setAttribute('aria-expanded', 'true')
        if (mobileQuery.matches) {
          sidebar.removeAttribute('inert')
          mainContent?.setAttribute('inert', '')
          topbar?.setAttribute('inert', '')
          firstFocusable().focus()
        }
      }

      const close = (restoreFocus = true) => {
        shell.classList.remove('is-open')
        menu.setAttribute('aria-expanded', 'false')
        if (mobileQuery.matches) {
          sidebar.setAttribute('inert', '')
          mainContent?.removeAttribute('inert')
          topbar?.removeAttribute('inert')
          if (restoreFocus) menu.focus()
        }
      }

      // Sync inert state when the viewport crosses the 820px breakpoint.
      mobileQuery.addEventListener('change', () => {
        if (shell.classList.contains('is-open')) {
          close(false)
        }
        applyInertForMobileClosed()
      })

      // Set initial inert state for the sidebar when at mobile widths and closed.
      applyInertForMobileClosed()

      menu.addEventListener('click', () =>
        shell.classList.contains('is-open') ? close() : open(),
      )
      backdrop?.addEventListener('click', () => close())
      sidebar.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a')) close()
      })
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && shell.classList.contains('is-open')) close()
      })
    }

    initDocsDrawer()
    document.addEventListener('astro:after-swap', initDocsDrawer)
  </script>
</Base>
