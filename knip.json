{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": true,
  "ignoreWorkspaces": ["packages/cucumber"],
  "workspaces": {
    "packages/var-core": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-cli": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-vitest": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var": {
      "entry": ["src/index.ts", "tests/**/*.test.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-language": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-lsp": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-vscode": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@oselvar/var-language", "@oselvar/var-lsp"]
    },
    "packages/var-examples": {
      "entry": ["**/*.md", "**/*.steps.ts"],
      "project": ["**/*.{ts,md}"]
    },
    "conformance": {
      "entry": ["bundles/**/*.steps.ts", "bundles/**/*.md"],
      "project": ["bundles/**/*.{ts,md}"]
    }
  },
  "ignore": [
    "var.config.ts",
    "**/tests/fixtures/**",
    "packages/website/src/layouts/Doc.astro",
    "**/!(package).json"
  ]
}
