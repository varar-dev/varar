{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": true,
  "ignoreWorkspaces": ["packages/cucumber"],
  "workspaces": {
    "packages/var": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-cli": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-vitest": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-runtime": {
      "entry": [
        "src/index.ts",
        "tests/**/*.test.ts",
        "bundles/**/*.steps.ts",
        "bundles/**/*.var.md"
      ],
      "project": ["src/**/*.ts", "tests/**/*.ts", "bundles/**/*.{ts,var.md}"]
    },
    "packages/var-language": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-lsp": {
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/var-vscode": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@oselvar/var-language", "@oselvar/var-lsp"]
    },
    "docs/tutorial": {
      "entry": ["**/*.var.md", "**/*.steps.ts"],
      "project": ["**/*.{ts,var.md}"]
    }
  },
  "ignore": ["var.config.ts", "**/tests/fixtures/**", "packages/website/src/layouts/Doc.astro"]
}
