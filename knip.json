{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "packages/bdd": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/bdd-cli": {
      "entry": ["src/index.ts", "src/bin.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/bdd-vitest": {
      "entry": ["src/index.ts", "src/runtime.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/bdd-language": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/bdd-lsp": {
      "entry": ["src/server.ts", "src/bin.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "docs/tutorial": {
      "entry": ["**/*.bdd.md", "**/*.steps.ts", "vitest.config.ts"],
      "project": ["**/*.{ts,bdd.md}"]
    }
  },
  "ignore": ["bdd.config.ts"]
}
