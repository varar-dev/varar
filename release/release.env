# 1Password secret references (no real secrets — resolved by `op run`).
# The vault is "Vár" in the my.1password.com account, referenced by ID because
# op:// URIs reject non-ASCII vault names. release.sh exports OP_ACCOUNT.
#   op vault get qtfavpq3rme5n4jbzphovovov4 --account my.1password.com
NPM_TOKEN=op://qtfavpq3rme5n4jbzphovovov4/npm/token
UV_PUBLISH_TOKEN=op://qtfavpq3rme5n4jbzphovovov4/pypi/token
CENTRAL_USERNAME=op://qtfavpq3rme5n4jbzphovovov4/sonatype-central/username
CENTRAL_PASSWORD=op://qtfavpq3rme5n4jbzphovovov4/sonatype-central/password
MAVEN_GPG_PASSPHRASE=op://qtfavpq3rme5n4jbzphovovov4/maven-gpg/passphrase
VSCE_PAT=op://qtfavpq3rme5n4jbzphovovov4/vscode-marketplace/pat
OVSX_PAT=op://qtfavpq3rme5n4jbzphovovov4/open-vsx/pat
GEM_HOST_API_KEY=op://qtfavpq3rme5n4jbzphovovov4/rubygems/apikey
# crates.io: consumed by `cargo publish` in 65-crates-io.sh once crates.io
# publishing is un-parked (CRATES_IO_ENABLED=1 in lib.sh). Resolved on every
# release preflight, so the `crates` item must exist even while parked.
CARGO_REGISTRY_TOKEN=op://qtfavpq3rme5n4jbzphovovov4/crates/token
