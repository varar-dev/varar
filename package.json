{
  "name": "oselvar-var",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc -p tsconfig.tests.json",
    "test": "NODE_OPTIONS=\"--import tsx\" vitest run",
    "test:watch": "NODE_OPTIONS=\"--import tsx\" vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "knip": "knip",
    "jscpd": "jscpd packages",
    "install:vscode": "pnpm -r --filter @oselvar/var-lsp --filter oselvar-var build && node scripts/install-vscode.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm knip && pnpm jscpd"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "jscpd": "^5.0.8",
    "knip": "^6.16.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
